<mujoco model="Turtle 3D Swimming">
  <include file="../common.xml" />
  <include file="turtle_3dswimming_model.xml" />

  <custom>
    <numeric name="agent_planner" data="6" />
    <numeric name="agent_horizon" data="2.0" />
    <numeric name="agent_timestep" data="0.02" />
    <numeric name="sampling_trajectories" data="64" />
    <numeric name="sampling_spline_points" data="5" />
    <numeric name="sampling_exploration" data="0.1" />
    <numeric name="gradient_spline_points" data="15" />
    <numeric name="estimator" data="0" />
    
    <!-- Generic body-motion locomotion controller parameters -->
    <numeric name="residual_DesiredSpeed"       data="0.60" />
    <numeric name="residual_SlowRadius"         data="0.20" />
    <numeric name="residual_LocAxisX"           data="0.0" />
    <numeric name="residual_LocAxisY"           data="-1.0" />
    <numeric name="residual_LocAxisZ"           data="0.0" />
    <numeric name="residual_UpAxisX"            data="0.0" />
    <numeric name="residual_UpAxisY"            data="0.0" />
    <numeric name="residual_UpAxisZ"            data="1.0" />
    <numeric name="residual_EnvNormalX"         data="0.0" />
    <numeric name="residual_EnvNormalY"         data="0.0" />
    <numeric name="residual_EnvNormalZ"         data="1.0" />
    
    <!-- Control smoothing (first-order low-pass filter) -->
    <numeric name="residual_ControlSmoothingEnabled" data="1" />
    <numeric name="residual_ControlSmoothingTau"    data="0.08" />
  </custom>

  <worldbody>
    <!-- Target placed in front of the robot head (-Y direction in turtle.xml frame) -->
    <body name="target" mocap="true" pos="-0.196 -1.5 0.0717682">
      <geom name="target" type="sphere" size="0.05" material="target"/>
      <light name="target_light" diffuse=".7 .7 .7" pos="0 0 0.5"/>
    </body>
  </worldbody>

  <sensor>
    <!-- Cost terms: 17 total residuals (indices 0-16) -->
    <!-- [0-2]:    3D position error -->
    <!-- [3]:      one-sided forward progress floor -->
    <!-- [4-6]:    cross-track / slip velocity vector -->
    <!-- [7-9]:    locomotion-axis alignment vector -->
    <!-- [10-12]:  trim relative to environment normal -->
    <!-- [13-15]:  angular-rate damping orthogonal to environment normal -->
    <!-- [16]:     scalar control effort -->
    <user name="Position" dim="3" user="0 2.0  0 100.0" />
    <user name="Progress" dim="1" user="0 8.0  0 1.0" />
    <user name="Slip"     dim="3" user="0 3.0  0 10.0" />
    <user name="Align"    dim="3" user="0 2.5  0 10.0" />
    <user name="Trim"     dim="3" user="0 1.0  0 10.0" />
    <user name="AngVel"   dim="3" user="0 0.5  0 10.0" />
    <user name="Control"  dim="1" user="0 0.01 0 1.0" />

    <!-- State/position sensors referenced in turtle_3dswimming.cc -->
    <framepos    name="base_pos_task"        objtype="site" objname="head_pos" />
    <framepos    name="target_pos_task"      objtype="body" objname="target" />
    <framelinvel name="base_vel_world_task"  objtype="site" objname="head_pos" />
    <frameangvel name="base_angvel_world_task" objtype="site" objname="head_pos" />
    
    <!-- Legacy sensors for backward compatibility (not used by main controller) -->
    <framepos    name="head_pos_task"       objtype="site" objname="head_pos" />
    <framepos    name="tail_pos_task"       objtype="site" objname="tail_pos" />
  </sensor>
</mujoco>