<!-- this file builds a general environment in mujoco -->
<mujoco>
  <compiler meshdir="asset" texturedir="asset"/>
  <visual>
    <rgba haze="0.15 0.25 0.35 1"/>
    <quality shadowsize="4096"/>
    <map stiffness="700" shadowscale="0.5" fogstart="10" fogend="15" zfar="40" haze="0.3"/>
  </visual>
  <option tolerance="1e-9"/>
  <asset>
    <texture type="skybox" builtin="gradient" rgb1="1 1 1" rgb2="1 1 1" width="512" height="512"/>
    <texture name="texplane" type="2d" builtin="checker" rgb1=".6 .6 .5" rgb2="0 0 0"
      width="512" height="512" mark="cross" markrgb=".8 .8 .8"/>
    <material name="matplane" reflectance="0.2" texture="texplane" texrepeat="1 1" texuniform="true"/>
  </asset>

  <worldbody>

    <light directional="true" diffuse=".4 .4 .4" specular="0.1 0.1 0.1" pos="0 0 5.0" dir="0 0 -1" castshadow="false"/>
    <light directional="true" diffuse=".6 .6 .6" specular="0.2 0.2 0.2" pos="0 0 4" dir="0 0 -1"/>
    <body name="ground" >
      <geom name="ground" type="plane" size="0 0 1" pos="0 0 -1" quat="1 0 0 0" material="matplane" condim="1" friction="0.5 0 0"/>
    </body>
  </worldbody>
</mujoco>
